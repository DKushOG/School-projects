<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Bookings</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<!-- Navbar include -->
  <%- include('../partials/navbar') %>
  <div class="container py-5">
    <!-- Bookings page header -->
    <h1 class="mb-4">My Bookings</h1>

    <!-- Conditional: No bookings -->
    <% if (bookings.length === 0) { %>
        <div class="alert alert-warning">You haven't made any bookings yet.</div>
    <% } else { %>
        <!-- Table of bookings -->
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Ticket Type</th>
                    <th>Quantity</th>
                </tr>
            </thead>
            <tbody>
                <% bookings.forEach(booking => { %>
                    <tr>
                        <td><%= booking.title %></td>
                        <td><%= booking.event_date %></td>
                        <td><%= booking.ticket_type %></td>
                        <td><%= booking.total %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
    
    <!-- Navigation buttons -->
    <div class="mt-4">
        <a href="/attendee" class="btn btn-secondary">Back to Events</a>
        <a href="/logout" class="btn btn-danger float-end">Logout</a>
    </div>
  </div>
</body>
</html>
