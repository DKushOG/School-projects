<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Available Events</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<!-- Navbar for logged-in attendee -->
  <%- include('../partials/navbar') %>
  <div class="container py-5">
    <!-- Main heading for the page -->
    <h1 class="mb-4">Available Events</h1>

    <!-- Conditional: No events available -->
    <% if (events.length === 0) { %>
        <div class="alert alert-warning">No published events are currently available. Please check back soon!</div>
    <% } else { %>

        <!-- Loop: Render each event as a Bootstrap card -->
        <div class="row row-cols-1 row-cols-md-2 g-4">
            <% events.forEach(event => { %>
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title"><%= event.title %></h5>
                            <p class="card-text"><%= event.description %></p>
                            <p><strong>Date:</strong> <%= event.event_date %></p>
                            <p>
                                <strong>Tickets Left:</strong> 
                                <%= event.ticket_count_full %> Full-price,
                                <%= event.ticket_count_concession %> Concession
                            </p>
                            <!-- Card shows title, description, date, ticket availability -->
                            <% if ((event.ticket_count_full + event.ticket_count_concession) === 0) { %>
                                <!-- If no tickets left -->
                                <span class="badge bg-danger">SOLD OUT</span>
                            <% } else { %>
                                <!-- Show Book/View button -->
                                <a href="/attendee/event/<%= event.event_id %>" class="btn btn-primary">View & Book</a>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>

    <!-- Navigation buttons -->
    <div class="mt-4">
        <a href="/" class="btn btn-outline-primary me-2">Back to Main Site</a>
        <a href="/attendee/my-bookings" class="btn btn-outline-secondary me-2">My Bookings</a>
        <a href="/logout" class="btn btn-danger float-end">Logout</a>
    </div>
  </div>
</body>
</html>
