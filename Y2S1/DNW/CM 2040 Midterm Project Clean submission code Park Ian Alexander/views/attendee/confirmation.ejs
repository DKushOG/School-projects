<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking Confirmed</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-5 text-center">
    <!-- Simple confirmation message after booking -->
    <h1 class="text-success">Booking Confirmed!</h1>
    <p>Thank you for your booking. You will receive a confirmation soon.</p>
    <p>You booked <strong><%= qty %></strong> 
        <%= type === 'full' ? 'Full-price' : type === 'concession' ? 'Concession' : type %> ticket(s).
    </p>

    <!-- Link to return to homepage -->
    <a href="/" class="btn btn-primary mt-3">Return to Homepage</a>
</body>
</html>
