<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <!-- Page for a specific event -->
    <title><%= event.title %> - Book Tickets</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-5">
    <!-- Display event information -->
    <h1><%= event.title %></h1>
    <p><strong>Date:</strong> <%= event.event_date %></p>
    <p><strong>Description:</strong> <%= event.description %></p>

    <!-- Show any error/success feedback -->
    <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
    <% } %>

    <!-- Booking form -->
    <form action="/attendee/event/<%= event.event_id %>" method="POST" class="mt-4">
        <div class="mb-3">
            <!-- Select ticket type with radio buttons -->
            <label class="form-label">Ticket Type</label><br>
            <div class="form-check">
            <input class="form-check-input" type="radio" name="ticket_type" value="full" <%= previous && previous.ticket_type === 'full' ? 'checked' : '' %> required>
            <label class="form-check-label">
                Full-price – £<%= event.price_full.toFixed(2) %> each, 
                <%= event.ticket_count_full %> available
            </label>
            </div>
            <div class="form-check">
            <input class="form-check-input" type="radio" name="ticket_type" value="concession" <%= previous && previous.ticket_type === 'concession' ? 'checked' : '' %> required>
            <label class="form-check-label">
                Concession – £<%= event.price_concession.toFixed(2) %> each, 
                <%= event.ticket_count_concession %> available
            </label>
            </div>
        </div>

        <!-- Input ticket quantity -->
        <div class="mb-3">
            <label class="form-label">Quantity</label>
            <input class="form-control" type="number" name="quantity" min="1" value="<%= previous ? previous.quantity : 1 %>" required>
        </div>

        <!-- Submit button -->
        <button type="submit" class="btn btn-success">Book Tickets</button>
        <a href="/attendee" class="btn btn-danger">Back</a>
    </form>
</body>
</html>
