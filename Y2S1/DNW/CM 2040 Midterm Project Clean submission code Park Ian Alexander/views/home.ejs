<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= site.name %> – Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Include site-wide navigation bar -->
  <%- include('partials/navbar', { user: user }) %>
  <div class="container py-5">

  <!-- Display site name and description -->
  <h1 class="mb-3"><%= site.name %></h1>
  <p class="lead mb-4"><%= site.description %></p>

  <!-- Show different controls based on logged-in user's role -->
  <% if (user) { %>
    <!-- Logged-In User Controls -->
    <% if (user.role === 'attendee') { %>
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>Welcome, <%= user.username %></h4>
        <div>
          <a href="/attendee" class="btn btn-outline-secondary me-2">Event Dashboard</a>
          <a href="/attendee/my-bookings" class="btn btn-outline-secondary me-2">My Bookings</a>
          <a href="/logout" class="btn btn-danger">Logout</a>
        </div>
      </div>
    <% } else if (user.role === 'organiser') { %>
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>Welcome, <%= user.username || 'Admin' %></h4>
        <div>
          <a href="/organiser" class="btn btn-outline-primary me-2">Manage Events</a>
          <a href="/logout" class="btn btn-danger">Logout</a>
        </div>
      </div>
    <% } %>
  <% } else { %>
    <!-- Anonymous View Buttons -->
    <div class="mb-4">
      <a href="/login" class="btn btn-success">Login</a>
      <a href="/register" class="btn btn-outline-primary ms-2">Register</a>
    </div>
  <% } %>
  <!-- Featured Event Section -->
  <h4 class="mt-4">Featured Event:</h4>
  <% if (featured) { %>
    <div class="card mt-2 mb-4">
      <div class="card-body">
        <h5 class="card-title"><%= featured.title %></h5>
        <p class="card-text"><%= featured.description %></p>
        <p><strong>Date:</strong> <%= featured.event_date %></p>
        <p>
          <strong>Tickets Left:</strong>
          <%= featured.ticket_count_full %> Full-price,
          <%= featured.ticket_count_concession %> Concession
        </p>
        <% if ((featured.ticket_count_full + featured.ticket_count_concession) === 0) { %>
          <span class="badge bg-danger">SOLD OUT</span>
        <% } else if (user && user.role === 'attendee') { %>
          <a href="/attendee/event/<%= featured.event_id %>" class="btn btn-primary">Book Featured Event</a>
        <% } %>
      </div>
    </div>
  <% } else { %>
    <p class="text-muted">No featured event available right now.</p>
  <% } %>

  <!-- Other Events (attendee & organiser only) -->
  <% if (user && (user.role === 'attendee' || user.role === 'organiser')) { %>
    <h4 class="mt-5">All Published Events</h4>
    <% if (events && events.length > 0) { %>
      <div class="row row-cols-1 row-cols-md-2 g-4">
        <% events.forEach(event => { %>
          <% if (!featured || event.event_id !== featured.event_id) { %> <!-- Hide featured duplicate -->
            <div class="col">
              <div class="card h-100">
                <div class="card-body">
                  <h5 class="card-title"><%= event.title %></h5>
                  <p class="card-text"><%= event.description %></p>
                  <p><strong>Date:</strong> <%= event.event_date %></p>
                  <p>
                    <strong>Tickets Left:</strong>
                    <%= event.ticket_count_full %> Full-price,
                    <%= event.ticket_count_concession %> Concession
                  </p>
                  <% if ((event.ticket_count_full + event.ticket_count_concession) === 0) { %>
                    <span class="badge bg-danger">SOLD OUT</span>
                  <% } else if (user && user.role === 'attendee') { %>
                    <a href="/attendee" class="btn btn-primary">View</a>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-muted">No published events available.</p>
    <% } %>
  <% } %>
 </div> 
</body>
</html>

</html>
