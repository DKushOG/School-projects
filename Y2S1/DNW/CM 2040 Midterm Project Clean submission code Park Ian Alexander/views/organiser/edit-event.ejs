<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Event</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
  <!-- Include navigation bar with site and user info -->
  <%- include('../partials/navbar', { site: siteInfo, user: user }) %>
  <div class="container py-4">

  <!-- Event form title -->
  <h2 class="mb-4">Edit Event</h2>

  <!-- Show any error message -->
  <% if (typeof error !== 'undefined') { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <!-- Event edit form -->
  <form method="POST" action="<%= isEdit ? '/organiser/edit/' + event.id : '/organiser/add' %>">
    <div class="mb-3">
       <!-- Title input -->
      <label class="form-label">Event Title</label>
      <input class="form-control" type="text" name="title" value="<%= event.title %>" required />
    </div>
    <div class="mb-3">
      <!-- Description text area -->
      <label class="form-label">Event Description</label>
      <textarea class="form-control" name="description" rows="4" required><%= event.description %></textarea>
    </div>
    <div class="mb-3">
       <!-- Date input -->
      <label class="form-label">Event Date</label>
      <input class="form-control" type="date" name="event_date" value="<%= event.event_date %>" required />
    </div>
    <!-- Ticket count inputs -->
    <!-- Full-price tickets -->
    <div class="mb-3">
      <label class="form-label">Number of Full-price Tickets</label>
      <input class="form-control" type="number" name="ticket_count_full" value="<%= event.ticket_count_full || 0 %>" min="0" />
    </div>
    <div class="mb-3">
      <label class="form-label">Price per Full-price Ticket (£)</label>
      <input class="form-control" type="number" step="0.01" name="price_full" value="<%= event.price_full || 0 %>" min="0" />
    </div>

    <!-- Concession tickets -->
    <div class="mb-3">
      <label class="form-label">Number of Concession Tickets</label>
      <input class="form-control" type="number" name="ticket_count_concession" value="<%= event.ticket_count_concession || 0 %>" min="0" />
    </div>
    <div class="mb-3">
      <label class="form-label">Price per Concession Ticket (£)</label>
      <input class="form-control" type="number" step="0.01" name="price_concession" value="<%= event.price_concession || 0 %>" min="0" />
    </div>

    <!-- Featured checkbox -->
    <div class="form-check mb-3">
      <input class="form-check-input" type="checkbox" id="isFeatured" name="is_featured" <%= event.is_featured ? 'checked' : '' %>>
      <label class="form-check-label" for="isFeatured">
        Mark as featured on homepage
      </label>
    </div>

    <button class="btn btn-primary">Update Event</button>
  </form>
  <br />
  <!-- Button to return to organiser dashboard -->
  <a href="/organiser" class="btn btn-secondary">Back to Organiser Home</a>
  </div>
</body>
</html>
