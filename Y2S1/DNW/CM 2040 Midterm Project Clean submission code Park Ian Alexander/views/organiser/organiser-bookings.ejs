<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Organiser Bookings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Include navigation bar with site and user info -->
  <%- include('../partials/navbar', { site: siteInfo, user: user }) %>
  <div class="container py-4">

  <!-- Bookings table header -->
  <h2>All Bookings</h2>

  <!-- Conditional: No bookings -->
  <% if (bookings.length === 0) { %>
        <div class="alert alert-warning">No bookings yet.</div>
    <% } else { %>
  <!-- Table of attendee bookings for a specific event -->
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Event</th>
        <th>User</th>
        <th>Type</th>
        <th>Quantity</th>
      </tr>
    </thead>
    <tbody>
      <% bookings.forEach(booking => { %>
        <tr>
          <td><%= booking.event_name %></td>
          <td><%= booking.username %></td>
          <td>
            <%= booking.ticket_type === 'full' ? 'Full-price' :
                booking.ticket_type === 'concession' ? 'Concession' :
                booking.ticket_type %>
          </td>
          <td><%= booking.quantity %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
  <!-- Return to organiser dashboard -->
  <a class="btn btn-secondary" href="/organiser">Back to Home</a>
  </div>
</body>
</html>
