<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Organiser Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
  <!-- Include navigation bar with site and user info -->
  <%- include('../partials/navbar', { site: siteInfo, user: user }) %>
  <div class="container py-4">
  <a href="/" class="btn btn-outline-secondary mb-3">← Back to Main Site</a>
  <!-- Display any error message passed to the view -->
  <% if (typeof error !== 'undefined') { %>
  <div class="alert alert-danger">
    <%= error %>
  </div>
  <% } %>
  <!-- Welcome and site info section -->
  <h4 class="mb-3">Welcome, Admin</h4>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <!-- Site name and description + settings/logout buttons -->
      <h2><%= siteInfo.name %></h2>
      <p class="mb-0"><%= siteInfo.description %></p>
    </div>
    <div>
      <a href="/settings" class="btn btn-outline-secondary me-2">Site Settings</a>
      <a href="/logout" class="btn btn-danger">Logout</a>
    </div>
  </div>
  <!-- Button to add a new event -->
  <a class="btn btn-success mb-3" href="/organiser/add">Create New Event</a>

  <!-- Published Events -->
<h2 class="mt-5">Published Events</h2>
<% if (published.length === 0) { %>
  <p>No published events yet.</p>
<% } else { %>
  <div class="list-group">
    <!-- Loop through and display each published event -->
    <!-- Includes buttons to view bookings, delete, and toggle feature status -->
    <% published.forEach(event => { %>
      <div class="list-group-item">
        <h5><%= event.title %></h5>
        <p><%= event.description %></p>
        <p><strong>Date:</strong> <%= event.event_date ? event.event_date : 'TBA' %></p>
        <!-- Displays remaining tickets and a Sold out message if there are none left -->
        <p>
          <strong>Tickets Left:</strong>
          <%= event.ticket_count_full %> Full-price,
          <%= event.ticket_count_concession %> Concession
        </p>
        <% if ((event.ticket_count_full + event.ticket_count_concession) === 0) { %>
          <span class="badge bg-danger">SOLD OUT</span>
        <% } %>
        <form action="/organiser/bookings/<%= event.event_id %>" method="get" style="display:inline;">
          <button type="submit" class="btn btn-sm btn-info">View Bookings</button>
        </form>
        <form action="/organiser/delete/<%= event.event_id %>" method="post" style="display:inline;">
          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
        </form>
        <form method="POST" action="/organiser/toggle-feature/<%= event.event_id %>" style="display:inline;">
        <% if (event.is_featured) { %>
          <button class="btn btn-sm btn-warning">Unfeature</button>
        <% } else { %>
          <button class="btn btn-sm btn-outline-primary">Feature</button>
        <% } %>
        </form>
      </div>
    <% }); %>
  </div>
<% } %>

<!-- Draft Events -->
<h2 class="mt-5">Draft Events</h2>
<% if (drafts.length === 0) { %>
  <p>No draft events.</p>
  <% } else { %>
    <div class="list-group">
      <!-- Loop through and display each draft event -->
      <!-- Includes buttons to edit, publish, or delete -->
      <% drafts.forEach(event => { %>
        <div class="list-group-item">
          <h5><%= event.title %></h5>
          <p><%= event.description %></p>
          <p><strong>Date:</strong> <%= event.event_date ? event.event_date : 'TBA' %></p>
          <p>
            <strong>Tickets:</strong>
            <%= event.ticket_count_full %> Full-price,
            <%= event.ticket_count_concession %> Concession
          </p>
          <form action="/organiser/edit/<%= event.event_id %>" method="get" style="display:inline;">
            <button type="submit" class="btn btn-sm btn-warning">Edit</button>
          </form>
          <form action="/organiser/publish/<%= event.event_id %>" method="post" style="display:inline;">
            <button type="submit" class="btn btn-sm btn-success">Publish</button>
          </form>
          <form action="/organiser/delete/<%= event.event_id %>" method="post" style="display:inline;">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
</body>
</html>
