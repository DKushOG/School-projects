<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Site Settings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Include navigation bar with site and user info -->
  <%- include('../partials/navbar', { site: siteInfo, user: user }) %>
  <div class="container py-4">
  <h2>Organiser Site Settings</h2>

  <!-- Site settings form -->
  <form action="/settings" method="POST">
    <!-- Site name and description input fields -->
    <div class="mb-3">
      <!-- Name input -->
      <label class="form-label">Site Name</label>
      <input type="text" class="form-control" name="site_name" value="<%= settings.site_name %>" required />
    </div>
    <div class="mb-3">
      <!-- Description text area -->
      <label class="form-label">Site Description</label>
      <textarea class="form-control" name="site_description" rows="4"><%= settings.site_description %></textarea>
    </div>
     <!-- Save button -->
    <button class="btn btn-primary">Save Settings</button>
  </form>
  
  <!-- Return to organiser dashboard -->
  <a class="btn btn-link mt-3" href="/organiser">Back to Organiser Home</a>
  </div>
</body>
</html>
