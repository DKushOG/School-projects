<!-- Extract site name and current user for easier use -->
<% const siteName = site?.name || 'Home'; %>
<% const currentUser = user || null; %>

<!-- Bootstrap Navbar Component -->
<nav class="navbar navbar-expand-lg navbar-light bg-white px-3 mb-4" style="box-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);">
  <div class="container-fluid">
    <!-- Branding (site name or fallback to 'Home') -->
    <a class="navbar-brand" href="/"><%= site?.name || 'Home' %></a>

     <!-- Navbar toggle for mobile view -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
      data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false"
      aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Right-aligned navbar items -->
    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
      <ul class="navbar-nav">
        <!-- Anonymous User View -->
        <% if (!currentUser) { %>
          <!-- Anonymous users -->
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/register">Register</a>
          </li>

        <!-- Attendee View -->
        <% } else if (currentUser && currentUser.role === 'attendee'){ %>
          <!-- Attendee -->
          <li class="nav-item">
            <span class="nav-link disabled px-2 text-dark fw-bold" style="cursor: default;">Having a great day, <%= user.username %>?</span>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/attendee">Event Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-danger" href="/logout">Logout</a>
          </li>

        <!-- Organiser View -->
        <% } else if (user.role === 'organiser') { %>
          <!-- Organiser -->
          <li class="nav-item">
            <span class="nav-link disabled px-2 text-dark fw-bold" style="cursor: default;"><%= user.username || Admin%></span>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/organiser">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/organiser/add">Create Event</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/settings">Site Settings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-danger" href="/logout">Logout</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
